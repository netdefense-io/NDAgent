	"scripts": {
		"post-install": "if [ -f /usr/local/etc/ndagent.conf ] && ! [ -e /var/db/ndagent/device.key ]; then PRIVKEY=$(grep '^device_privkey=' /usr/local/etc/ndagent.conf 2>/dev/null | head -1 | cut -d= -f2- | tr -d '[:space:]'); if [ -n \"$PRIVKEY\" ]; then mkdir -p /var/db/ndagent; chmod 0700 /var/db/ndagent; echo \"$PRIVKEY\" > /var/db/ndagent/device.key; chmod 0600 /var/db/ndagent/device.key; chown root:wheel /var/db/ndagent/device.key; echo \"Migrated device_privkey to /var/db/ndagent/device.key (issue #15)\"; fi; fi\nif [ -f /usr/local/etc/rc.d/configd ]; then /usr/local/etc/rc.d/configd restart; fi\nif [ -f /usr/local/opnsense/mvc/script/run_migrations.php ]; then /usr/local/opnsense/mvc/script/run_migrations.php OPNsense/NetDefense; fi\nif [ -f /usr/local/etc/rc.configure_plugins ]; then echo \"Reloading plugin configuration\"; /usr/local/etc/rc.configure_plugins POST_INSTALL; fi\nif [ -f /usr/local/sbin/configctl ]; then echo -n \"Reloading template OPNsense/NetDefense: \"; /usr/local/sbin/configctl template reload OPNsense/NetDefense; fi; if [ -f /usr/local/etc/rc.d/ndagent ]; then echo \"Starting ndagent (if enabled)\"; /usr/local/etc/rc.d/ndagent start; fi",
		"post-deinstall": "if [ -f /usr/local/etc/rc.configure_plugins ]; then echo \"Reloading plugin configuration\"; /usr/local/etc/rc.configure_plugins POST_DEINSTALL; fi",
		"pre-deinstall": "if [ -f /usr/local/etc/rc.d/ndagent ]; then echo \"Stopping ndagent (if enabled)\"; /usr/local/etc/rc.d/ndagent stop; fi",
	}
}
